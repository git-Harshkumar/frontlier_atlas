# ---------------------------
# Daily Sync Script
# NOTE: These variables are used by scripts/daily-sync.ts only.
# They are NOT read by the Cloudflare Worker runtime (src/index.ts).
# ---------------------------

# How many hours back to look for new papers on each sync run.
# Increase this if a sync was missed (e.g., 48 or 72 for a backfill).
# Default: 24
SYNC_LOOKBACK_HOURS=24

# Number of papers to insert per database transaction batch.
# Default: 100
SYNC_BATCH_SIZE=100

# ---------------------------
# HTTP Client (used by collectors)
# ---------------------------
# Maximum number of retries for a failed HTTP request.
# Default: 3
HTTP_MAX_RETRIES=3

# Timeout in milliseconds for each HTTP request.
# Default: 10000
HTTP_TIMEOUT_MS=10000

# Initial delay in milliseconds between retries (doubles with each retry).
# Default: 1000
HTTP_INITIAL_RETRY_DELAY_MS=1000

# ---------------------------
# API Keys (Optional)
# If not provided, collectors will attempt public unauthenticated endpoints.
# ---------------------------

# Hugging Face API token — improves rate limits on the HF papers API.
# Get one at: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxx

