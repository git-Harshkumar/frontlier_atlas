{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "scripts/daily-sync.ts",
    "prisma.config.ts"
  ],
  "exclude": [
    "scripts/importPaperAuthors.ts",
    "scripts/importPaperRepositories.ts",
    "scripts/importAuthors.ts",
    "scripts/importPapers.ts",
    "scripts/importRepositories.ts"
  ]
}